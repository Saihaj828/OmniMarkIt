# Copy to .env and adjust. All values have safe local defaults if omitted.

# --- Database ---
# Default (zero setup): SQLite file in backend/.
DATABASE_URL=sqlite:///./omnimarkit.db
# PostgreSQL example (uncomment & install psycopg):
# DATABASE_URL=postgresql+psycopg://omnimarkit:omnimarkit@localhost:5432/omnimarkit

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_HOURS=24

# --- Encryption (AES-256-GCM for OAuth tokens in calendar_connections) ---
ENCRYPTION_SECRET=change-me-too

# --- CORS / frontend ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Payments (Stripe) ---
# Leave as the stub to simulate. Set a real test/live key to process real
# charges, payouts (Stripe Connect transfers), and subscriptions.
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_PUBLISHABLE_KEY=pk_test_stub
PLATFORM_FEE_BPS=1500

# --- Background checks (Checkr) ---
# Leave blank to simulate. Set your Checkr key to run real background checks.
CHECKR_API_KEY=
CHECKR_PACKAGE=tasker_standard

# --- File uploads (PDF) ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760

# --- Video + recordings ---
# Public Jitsi server (free, no account). Use your own domain in production.
JITSI_DOMAIN=meet.jit.si
MAX_RECORDING_BYTES=209715200
# Recordings are free to view for this many days, then payable.
RECORDING_FREE_DAYS=7
RECORDING_PRICE_CENTS=499

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0
# True = run tasks inline (no worker needed). Set False in production.
CELERY_TASK_ALWAYS_EAGER=True

# --- Environment ---
# In 'production', startup skips auto table-create (use Alembic migrations).
ENV=development
